{
  "name": "ai-portal-backend",
  "version": "0.1.0",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "nodemon --exec ts-node src/index.ts",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --coverageThreshold='{\"global\":{\"branches\":5,\"functions\":5,\"lines\":5,\"statements\":5}}'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.0",
    "jsonwebtoken": "^9.0.0",
    "meilisearch": "^0.36.0",
    "multer": "^2.1.1",
    "pg": "^8.11.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "redis": "^4.6.0",
    "uuid": "^11.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.19.19",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^11.0.0",
    "jest": "^29.7.0",
    "pino-pretty": "^13.1.3",
    "supertest": "^6.3.4",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
