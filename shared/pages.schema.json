{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PageSpec",
  "type": "object",
  "required": ["title", "spaceId", "content"],
  "properties": {
    "title": { "type": "string" },
    "spaceId": { "type": "integer" },
    "content": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": { "type": "string", "enum": ["heading", "text", "table", "macro"] },
          "text": { "type": "string" },
          "headers": { "type": "array", "items": { "type": "string" } },
          "rows": { "type": "array", "items": { "type": "array", "items": { "type": "string" } } },
          "macroName": { "type": "string" },
          "macroProps": { "type": "object" }
        }
      }
    },
    "acl": {
      "type": "object",
      "properties": {
        "readers": { "type": "array", "items": { "type": "string" } },
        "editors": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
