# AI Portal Environment Variables
# Copy to .env and replace values

# ====================
# SECURITY (REQUIRED)
# ====================

# JWT secret — MUST be set. Generate with: openssl rand -hex 32
JWT_SECRET=

# Allowed CORS origins — comma-separated list
ALLOWED_ORIGINS=http://localhost:3000

# ====================
# Database
# ====================
DATABASE_URL=postgres://portal:password@postgres:5432/portal
POSTGRES_USER=portal
POSTGRES_PASSWORD=password
POSTGRES_DB=portal

# ====================
# Redis
# ====================
REDIS_URL=redis://redis:6379

# ====================
# Meilisearch
# ====================
MEILISEARCH_URL=http://meilisearch:7700
MEILI_MASTER_KEY=change_me_in_production

# ====================
# AI / OpenRouter
# ====================
OPENROUTER_API_KEY=

# OpenClaw Gateway (HTTP API — alternative AI provider)
# Start gateway on host: openclaw gateway start --listen 0.0.0.0:18789
# In Docker: backend connects via host.docker.internal
OPENCLAW_GATEWAY_URL=http://host.docker.internal:18789

# ====================
# Node
# ====================
NODE_ENV=production
PORT=3001
