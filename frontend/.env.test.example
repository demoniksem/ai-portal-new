# E2E Test Environment Variables
# Copy to .env.test and fill in values

# Frontend URL (default: http://localhost:3000)
E2E_BASE_URL=http://localhost:3000

# Backend API URL (default: http://localhost:3001)
E2E_BACKEND_URL=http://localhost:3001

# Admin credentials for E2E tests
E2E_ADMIN_EMAIL=admin@portal.com
E2E_ADMIN_PASSWORD=admin123

# Test user credentials (created during test setup)
E2E_TEST_EMAIL=e2e-test-$(date +%s)@test.com
E2E_TEST_PASSWORD=testpassword123
